name: mlflow-demo-iris

docker_env: 
  image: 127923327338.dkr.ecr.us-east-1.amazonaws.com/mlflow-demo-iris-base:latest # base docker image which contains the environment/dependencies for the MLFlow Project execution

entry_points:
  main:
    parameters:
      l1_ratio: {type: float, default: 0.1}
    command: "python src/demo-iris.py --l1-ratio {l1_ratio}"